#!/usr/bin/env bash
# Ensure the TrueNAS databases and app roles exist for the current stack.
# Reads the stack name from platform.yml.
set -euo pipefail

REGION="us-east-1"
STACK_NAME=$(platform-manifest project)

FN=$(aws ssm get-parameter --name /ahara/truenas-db/function-name \
  --query Parameter.Value --output text --region "${REGION}")

echo "Ensuring TrueNAS databases for ${STACK_NAME}..."
RESULT_FILE=$(mktemp)
aws lambda invoke \
  --function-name "${FN}" \
  --payload "{\"stack_name\":\"${STACK_NAME}\"}" \
  --cli-binary-format raw-in-base64-out \
  --region "${REGION}" \
  "${RESULT_FILE}" > /dev/null

RESULT=$(cat "${RESULT_FILE}")
rm "${RESULT_FILE}"

if echo "${RESULT}" | grep -q '"errorMessage"'; then
  echo "TrueNAS DB manage FAILED:"
  echo "${RESULT}" | python3 -m json.tool 2>/dev/null || echo "${RESULT}"
  exit 1
fi

echo "${RESULT}" | python3 -m json.tool 2>/dev/null || echo "${RESULT}"
