#!/usr/bin/env bash
# Runs seed SQL files for the current project.
set -euo pipefail

REGION="us-east-1"
PROJECT=$(platform-manifest project)
MIGRATIONS_DIR=$(platform-manifest migrations)

# Upload seed files first (they live under migrations/seed/)
if [ -d "${MIGRATIONS_DIR}/seed" ]; then
  BUCKET=$(aws ssm get-parameter --name /ahara/db/migrations-bucket \
    --query Parameter.Value --output text --region "${REGION}")
  echo "Uploading seed files..."
  aws s3 sync "${MIGRATIONS_DIR}/seed/" "s3://${BUCKET}/migrations/${PROJECT}/seed/" --quiet
fi

FN=$(aws ssm get-parameter --name /ahara/db/migrate-function \
  --query Parameter.Value --output text --region "${REGION}")

echo "Seeding ${PROJECT}..."
RESULT_FILE=$(mktemp)
aws lambda invoke \
  --function-name "${FN}" \
  --payload "{\"operation\":\"seed\",\"project\":\"${PROJECT}\"}" \
  --cli-binary-format raw-in-base64-out \
  --region "${REGION}" \
  "${RESULT_FILE}" > /dev/null

RESULT=$(cat "${RESULT_FILE}")
rm "${RESULT_FILE}"

if echo "${RESULT}" | grep -q '"errorMessage"'; then
  echo "Seed FAILED:"
  echo "${RESULT}" | python3 -m json.tool 2>/dev/null || echo "${RESULT}"
  exit 1
fi

echo "${RESULT}" | python3 -m json.tool 2>/dev/null || echo "${RESULT}"
